<?xml version="1.0"?>
<robot name="puzzlebot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       PROPERTIES  (tune these to match real hardware)
       ============================================================ -->
  <xacro:property name="base_mass"       value="0.5"/>
  <xacro:property name="wheel_mass"      value="0.05"/>
  <xacro:property name="caster_mass"     value="0.02"/>
  <xacro:property name="lidar_mass"      value="0.17"/>

  <!-- Robot body box (length x width x height) -->
  <xacro:property name="base_length"     value="0.18"/>
  <xacro:property name="base_width"      value="0.15"/>
  <xacro:property name="base_height"     value="0.07"/>

  <!-- Wheel cylinder -->
  <xacro:property name="wheel_radius"    value="0.05"/>
  <xacro:property name="wheel_width"     value="0.025"/>
  <xacro:property name="wheel_separation" value="0.19"/>  <!-- center-to-center -->

  <!-- Caster sphere -->
  <xacro:property name="caster_radius"   value="0.02"/>

  <!-- LiDAR cylinder (purely visual/TF reference) -->
  <xacro:property name="lidar_radius"    value="0.035"/>
  <xacro:property name="lidar_height"    value="0.04"/>

  <!-- ============================================================
       INERTIA MACROS
       ============================================================ -->
  <!-- Solid box -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(w*w+h*h)}" ixy="0" ixz="0"
        iyy="${m/12.0*(l*l+h*h)}" iyz="0"
        izz="${m/12.0*(l*l+w*w)}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder (axis = Z) -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(3*r*r+h*h)}" ixy="0" ixz="0"
        iyy="${m/12.0*(3*r*r+h*h)}" iyz="0"
        izz="${m/2.0*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid sphere -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${2.0/5.0*m*r*r}" ixy="0" ixz="0"
        iyy="${2.0/5.0*m*r*r}" iyz="0"
        izz="${2.0/5.0*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       WHEEL MACRO  (reused for left and right)
       ============================================================ -->
  <xacro:macro name="wheel" params="name y_reflect">
    <link name="${name}_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <origin xyz="0.052 ${y_reflect * wheel_separation/2.0} -0.0025" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- ============================================================
       LINKS
       ============================================================ -->

  <!-- Ground-projection frame (used by Nav2 for 2-D navigation) -->
  <link name="base_footprint"/>

  <!-- Main chassis -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
      </geometry>
      <material name="yellow">
        <color rgba="0.8 0.7 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" l="${base_length}" w="${base_width}" h="${base_height}"/>
  </link>

  <!-- Passive rear caster wheel -->
  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
  </link>

  <!-- LiDAR sensor frame -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${lidar_mass}" r="${lidar_radius}" h="${lidar_height}"/>
  </link>

  <!-- ============================================================
       WHEELS (via macro)
       ============================================================ -->
  <xacro:wheel name="wheel_r" y_reflect="-1"/>
  <xacro:wheel name="wheel_l" y_reflect="1"/>

  <!-- ============================================================
       JOINTS
       ============================================================ -->

  <!-- base_footprint → base_link  (lifted 5 cm off the ground) -->
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- base_link → caster (rear passive wheel) -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.03" rpy="0 0 0"/>
  </joint>

  <!-- base_link → lidar_link  (top-centre of the robot) -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.0 0.0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       GAZEBO CLASSIC — Material colours
       ============================================================ -->
  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="wheel_r_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
  </gazebo>
  <gazebo reference="wheel_l_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
  </gazebo>
  <gazebo reference="caster_link">
    <material>Gazebo/Grey</material>
    <!-- Low friction so it slides freely -->
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- ============================================================
       GAZEBO CLASSIC — Differential Drive plugin
       Publishes:  /odom  (nav_msgs/Odometry)
                   /tf    (odom → base_footprint)
       Subscribes: /cmd_vel  (geometry_msgs/Twist)
       ============================================================ -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <update_rate>30</update_rate>
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2*wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
    </plugin>
  </gazebo>

  <!-- ============================================================
       GAZEBO CLASSIC — LiDAR (ray) sensor plugin
       Publishes:  /scan  (sensor_msgs/LaserScan)
       Frame:      lidar_link
       ============================================================ -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>5.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
